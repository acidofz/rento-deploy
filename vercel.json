{
  "version": 2,
  "builds": [
    {
      "src": "rento-web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"   
      }
    },
    {
      "src": "rento-backend/index.js",   
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/rento-backend/index.js" },
    { "src": "/(.*)", "dest": "/rento-backend/index.js" }   
  ]
}